// For format details, see https://aka.ms/devcontainer.json
{
	"name": "WP Document Revisions Development",
	"build": {
		"dockerfile": "Dockerfile"
	},

	// Features to add to the dev container
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:1": {},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "22"
		},
		"ghcr.io/devcontainers/features/github-cli:1": {
			"version": "latest"
		}
	},

	// Minimum resources for wp-env (WordPress + MySQL containers)
	"hostRequirements": {
		"cpus": 2,
		"memory": "4gb",
		"storage": "16gb"
	},

	// Forward wp-env ports
	"forwardPorts": [
		8888,
		8889
	],

	// Set port attributes for better labels
	"portsAttributes": {
		"8888": {
			"label": "WordPress",
			"onAutoForward": "notify",
			"protocol": "https"
		},
		"8889": {
			"label": "WordPress Tests",
			"onAutoForward": "silent",
			"protocol": "https"
		}
	},

	// Install dependencies (runs on create and when sources change)
	"updateContentCommand": "composer install --optimize-autoloader --prefer-dist --no-interaction && npm install && NODE_OPTIONS=--max-old-space-size=512 npm run build:blocks",

	// Wait for dependencies before opening terminal
	"waitFor": "updateContentCommand",

	// Start WordPress via wp-env (uses .wp-env.json config); retry once on failure
	"postCreateCommand": "npx wp-env start || npx wp-env start",

	// Ensure wp-env is running on container restart (e.g., after Codespace sleep)
	"postStartCommand": "npx wp-env start",

	// Configure tool-specific properties
	"customizations": {
		"vscode": {
			"extensions": [
				"bmewburn.vscode-intelephense-client",
				"xdebug.php-debug",
				"wordpresstoolbox.wordpress-toolbox",
				"shevaua.phpcs",
				"recca0120.vscode-phpunit",
				"SanderRonde.phpstan-vscode",
				"dbaeumer.vscode-eslint",
				"eamodio.gitlens",
				"editorconfig.editorconfig",
				"streetsidesoftware.code-spell-checker",
				"GitHub.copilot"
			],
			"settings": {
				"php.validate.executablePath": "/usr/local/bin/php",
				"php.suggest.basic": false,
				"intelephense.environment.phpVersion": "8.4",
				"phpcs.enable": true,
				"phpcs.standard": "phpcs.ruleset.xml",
				"phpcs.executablePath": "${workspaceFolder}/bin/phpcs",
				"phpstan.configFile": "phpstan.neon.dist",
				"phpstan.binPath": "${workspaceFolder}/bin/phpstan",
				"editor.formatOnSave": false,
				"editor.tabSize": 4,
				"editor.insertSpaces": false,
				"files.trimTrailingWhitespace": true,
				"files.insertFinalNewline": true,
				"files.associations": {
					"*.php": "php"
				},
				"terminal.integrated.defaultProfile.linux": "bash",
				"intelephense.stubs": [
					"wordpress",
					"wordpress-globals",
					"wp-cli"
				]
			}
		}
	},

	"remoteUser": "vscode"
}
