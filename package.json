{
  "name": "wp-document-revisions",
  "version": "3.9.0",
  "description": "Document management and version control for WordPress",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "npm run build:blocks && npm run build:admin",
    "build:blocks": "wp-scripts build --webpack-src-dir=src/blocks --output-path=build/blocks",
    "build:admin": "node script/build.js",
    "build:check": "node -e \"const fs=require('fs'); const devFiles=fs.readdirSync('js').filter(f=>f.endsWith('.dev.js')); devFiles.forEach(f=>{const min=f.replace('.dev.js','.js'); if(!fs.existsSync('js/'+min)){console.error('Missing: '+min);process.exit(1);}; console.log('OK: '+f+' -> '+min);})\"",
    "start": "wp-scripts start --webpack-src-dir=src/blocks --output-path=build/blocks",
    "test:e2e": "npx playwright test --config=playwright.config.js",
    "test:e2e:ui": "npx playwright test --config=playwright.config.js --ui",
    "wp-env": "wp-env"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wp-document-revisions/wp-document-revisions.git"
  },
  "keywords": [
    "wordpress",
    "documents",
    "revisions",
    "version-control"
  ],
  "author": "WP Document Revisions Contributors",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@wordpress/e2e-test-utils-playwright": "^1.43.0",
    "@wordpress/env": "^11.3.0",
    "@wordpress/scripts": "^31.8.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^29.7.0",
    "terser": "^5.46.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/js/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "js/**/*.dev.js",
      "src/blocks/**/*.js",
      "!js/**/*.coffee",
      "!js/**/*.coffee2"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/js/setup.js"
    ],
    "transform": {
      "\\.[jt]sx?$": "babel-jest"
    },
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "<rootDir>/tests/js/__mocks__/styleMock.js"
    }
  }
}
