{
	"name": "wp-document-revisions/wp-document-revisions",
	"description": "A document management and version control plugin that allows teams of any size to collaboratively edit files and manage their workflow.",
	"license": "GPL-3.0-or-later",
	"authors": [
		{
			"name": "Ben Balter",
			"email": "ben@balter.com"
		}
	],
	"require": {},
	"require-dev": {
		"phpcsstandards/phpcsutils": "^1.1",
		"phpcsstandards/phpcsextra": "^1.4",
		"wp-coding-standards/wpcs": "~3.2",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"yoast/phpunit-polyfills": "*",
		"phpcompatibility/php-compatibility": "*",
		"phpcompatibility/phpcompatibility-paragonie": "*",
		"phpcompatibility/phpcompatibility-wp": "*",
		"phpstan/phpstan": "^2.1",
		"szepeviktor/phpstan-wordpress": "^2.0"
	},
	"config": {
		"bin-dir": "bin",
		"vendor-dir": "vendor",
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"build:scope": [
			"@composer install --working-dir=vendor-bin/scoper --no-progress --no-interaction",
			"@php vendor-bin/scoper/vendor/bin/php-scoper add-prefix --output-dir=vendor-prefixed --force --quiet"
		]
	}
}
